{
  "name": "architect-impact-lens",
  "displayName": "Architect Impact Lens",
  "description": "Surface cross-repo API impact from Architect in the editor",
  "version": "0.1.0",
  "publisher": "architect-app",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onLanguage:java",
    "onLanguage:typescript",
    "onLanguage:javascript"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "architect.showEndpointImpact",
        "title": "Architect: Show endpoint impact"
      }
    ],
    "configuration": {
      "title": "Architect",
      "properties": {
        "architect.apiUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "Architect API base URL"
        },
        "architect.jwtToken": {
          "type": "string",
          "default": "",
          "description": "JWT token from Architect (copy from browser after login)"
        },
        "architect.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show Architect impact CodeLens above detected HTTP routes"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
